@misc{doshi-velez_accountability_2017,
  title     = {{Accountability of AI Under the Law: The Role of Explanation}},
  url       = {https://arxiv.org/abs/1711.01134},
  doi       = {10.48550/arXiv.1711.01134},
  abstract  = {As AI systems become more capable, we will begin to use them for more complex tasks. Currently, AI systems are used in many situations where explanations for the AI system's behavior would be beneficial. Explanations of AI behavior may be required by law, may help build trust in AI systems, or may be necessary for identifying failures in AI systems. In this paper, we describe the contexts in which explanation is likely to be required and what forms of explanation might be acceptable.},
  number    = {{arXiv}:1711.01134},
  publisher = {{arXiv}},
