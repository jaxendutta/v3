	publisher = {Oxford University Press},
	author = {Millar, Jason},
	editor = {Dubber, Markus D. and Pasquale, Frank and Das, Sunit},
	year = {2020},
	date = {2020-01-01},
	pages = {442--461},
	langid = {english},
}

@incollection{jones_hacking_2017,
	address = {Oxford, United Kingdom},
	title = {Hacking {Metaphors} in the {Anticipatory} {Governance} of {Emerging} {Technology}: {The} {Case} of {Regulating} {Robots}},
	isbn = {978-0-19-968083-2},
	url = {https://doi.org/10.1093/oxfordhb/9780199680832.013.34},
	doi = {10.1093/oxfordhb/9780199680832.013.34},
	abstract = {This chapter develops the Metaphor Hacking framework as a four-step
	methodology for critically interrogating the metaphors through which emerging
	technologies are understood, drawing on Schön's concept of generative metaphor to
	argue that initial framings of new technologies operate as defensive mechanisms
	that constrain understanding and shape regulatory responses, and applying the
	framework to the case of robot regulation.},
	booktitle = {The {Oxford} {Handbook} of {Law}, {Regulation} and {Technology}},
	publisher = {Oxford University Press},
	author = {Jones, Meg Leta and Millar, Jason},
	editor = {Brownsword, Roger and Scotford, Eloise and Yeung, Karen},
	year = {2017},
	date = {2017-01-01},
	langid = {english},
}

