@incollection{millar_social_2020,
	address = {Oxford, United Kingdom},
	title = {Social {Failure} {Modes} in {Technology} and the {Ethics} of {AI}: {An} {Engineering} {Perspective}},
	isbn = {978-0-19-006739-7},
	url = {https://doi.org/10.1093/oxfordhb/9780190067397.001.0001},
	doi = {10.1093/oxfordhb/9780190067397.001.0001},
	abstract = {This chapter introduces the social failure mode framework for analyzing
	how technologies fail in social contexts, distinguishing conventional from moral
