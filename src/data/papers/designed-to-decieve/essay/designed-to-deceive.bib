}

@inproceedings{lacey_cuteness_2019,
	address = {Daegu, Republic of Korea},
	title = {Cuteness as a `{Dark} {Pattern}' in {Home} {Robots}},
	isbn = {978-1-4503-6321-1},
	url = {https://doi.org/10.1109/HRI.2019.8673274},
	doi = {10.1109/HRI.2019.8673274},
	abstract = {This paper argues that cuteness in home robot design operates as a dark
	pattern by creating an illusion of user sovereignty in which users believe they
	control the technology while data-driven machine learning algorithms process their
	collective data traces, and that this illusion is produced through aesthetic and
	behavioral design choices that exploit human responses to cute, lifelike entities.},
	booktitle = {2019 14th {ACM}/{IEEE} {International} {Conference} on {Human}-{Robot}
	{Interaction} ({HRI})},
	publisher = {IEEE},
	author = {Lacey, Catherine and Caudwell, Catherine},
	month = mar,
	year = {2019},
	date = {2019-03-11},
	pages = {374--381},
	langid = {english},
}

